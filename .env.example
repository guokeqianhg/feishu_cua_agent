# CUA-Lark backend example config. Copy to .env and fill real values locally.
# Never commit real API keys.

CUA_LARK_MODEL_PROVIDER=auto
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://example.com/compatible-mode/v1
OPENAI_MODEL_TEXT=qwen-plus
OPENAI_MODEL_VISION=qwen-vl-max

DRY_RUN=true
CUA_LARK_PLACEHOLDER_SCREENSHOT=true
CUA_LARK_ALLOW_UNHEALTHY_SCREENSHOT=false
CUA_LARK_ALLOW_MOCK_REAL_EXECUTION=false

CUA_LARK_MONITOR_INDEX=1
CUA_LARK_STEP_BY_STEP=false
CUA_LARK_AUTO_DEBUG=false
CUA_LARK_ABORT_FILE=./runs/ABORT

CUA_LARK_ARTIFACT_ROOT=./runs
CUA_LARK_REPORT_DIR=./runs/reports
SCREENSHOT_DIR=./runs/screenshots

MAX_TOTAL_STEPS=40
MAX_RETRY_PER_SUBTASK=2
CUA_LARK_MAX_REPLANS=2
CUA_LARK_WAIT_AFTER_ACTION_SECONDS=0.8

# Dangerous action guard. Keep disabled until you are using a harmless test chat.
CUA_LARK_ALLOW_SEND_MESSAGE=false
CUA_LARK_ALLOWED_IM_TARGET=

# Dangerous create guards. Keep disabled until you are ready to create harmless test data.
CUA_LARK_ALLOW_DOC_CREATE=false
CUA_LARK_ALLOW_CALENDAR_CREATE=false
CUA_LARK_ALLOW_CALENDAR_INVITE=false
